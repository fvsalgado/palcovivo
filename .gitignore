# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.env
venv/
env/

# Cache local — não versionar (dados raw temporários e cache HTTP)
data/cache/
!data/cache/.gitkeep

# Cache HTTP por venue (gerado em runtime, passado por artefacto entre jobs)
data/cache/_http/
data/cache/*/

# Logs — versionar latest.json e logs datados para notificações funcionarem
!data/logs/

# Backups de eventos — versionados (mantidos até 30 por venue)
# Não excluir: data/backups/ é commitado intencionalmente

# Node / Astro (frontend)
node_modules/
.astro/
dist/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Secrets
.env
.env.local
secrets.json
